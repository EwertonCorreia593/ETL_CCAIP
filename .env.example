# Credenciais da plataforma CCAI
CCAI_EMAIL=seu.email@exemplo.com
CCAI_SENHA=sua_senha_aqui

# Timeout de download em segundos (opcional, default: 900)
CCAI_DOWNLOAD_TIMEOUT=900

# Período de extração (opcional)
# Se não informado, usa os últimos 5 dias automaticamente.
# Para reprocessar um período específico, descomente e ajuste as datas:
# Formato: YYYY-MM-DD
# CCAI_DATA_INICIO=2026-03-12
# CCAI_DATA_FINAL=2026-04-20
